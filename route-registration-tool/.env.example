GOOGLE_API_KEY=SET_YOUR_GOOGLE_API_KEY

POLYGON_ROADS_API_URL=https://roads.googleapis.com/v2/roads:list
API_URL=https://roads.googleapis.com/selection/v1/projects/

VIEW_MODE=FALSE

# Max routes allowed per project
MAX_ROUTES_PER_PROJECT=1000

# Firebase loggin config
ENABLE_FIRESTORE_LOGGING=false
FIRESTORE_DATABASE_ID=YOUR_FIRESTORE_DATABASE_ID 

# GCS DB backup/restore (all config from env only)
# When enabled: backs up DB to GCS at interval; on startup restores from GCS if local DB missing
GCS_DB_BACKUP_ENABLED=false
GCS_DB_BACKUP_BUCKET=your-gcs-bucket-name
GCS_DB_BACKUP_OBJECT=db_backups/my_database.db
# Possible values: 5m | 30m | 1h | 6h | 24h
GCS_DB_BACKUP_INTERVAL=1h
# GCP project ID for GCS (required when backup enabled; fallback: GOOGLE_CLOUD_PROJECT)
GCS_DB_BACKUP_PROJECT=your-gcp-project-id
