# Database (defaults to SQLite file my_database.db under route-registration-tool if unset)
# Production: PostgreSQL with async driver, e.g.:
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# Local / tests (example):
# DATABASE_URL=sqlite+aiosqlite:///./my_database.db
# After changing to Postgres, run migrations once: poetry run alembic upgrade head

# Google Maps JavaScript API key. Used ONLY by the browser-served frontend
# (Maps JS loader). Backend Google Maps Platform calls authenticate via the
# service account / Application Default Credentials — no API key — and bill
# quota to the ADC principal's home project (the same one used by the GCP
# project-list lookup).
GOOGLE_API_KEY=SET_YOUR_GOOGLE_API_KEY

POLYGON_ROADS_API_URL=https://roads.googleapis.com/v2/roads:list
API_URL=https://roads.googleapis.com/selection/v1/projects/

VIEW_MODE=FALSE

# When true, one GCP project can be used by multiple app projects (multi-tenant).
# When false (default), one GCP project is tied to one app project.
ENABLE_MULTITENANT=false

# Controls which steps are SKIPPED in the "Create New Project" wizard.
#
# `NEW_PROJECT_CREATION_SKIP_STEPS` accepts a comma-separated list of 1-based step
# numbers to skip: 1,2,4.
#
# Step 3 (Project Name) is ALWAYS shown and is not affected by this env var.
#
# Steps (1-based):
# 1 = Google Cloud Project selection
# 2 = Dataset selection
# 3 = Project Name (always shown)
# 4 = Jurisdiction Boundary
#
# Defaults when a step is skipped:
# - Skip step 1: auto-select first accessible GCP project.
# - Skip step 2: datasetName defaults to "historical_roads_data".
# - Skip step 4: boundary defaults to a world-covering WGS84 Polygon and the overlay is hidden.
#
# Example: only show Project Name (Step 3)
# NEW_PROJECT_CREATION_SKIP_STEPS=1,2,4
NEW_PROJECT_CREATION_SKIP_STEPS=1,2,4

# Max routes allowed per project
MAX_ROUTES_PER_PROJECT=1000

# Firebase loggin config
ENABLE_FIRESTORE_LOGGING=false
FIRESTORE_DATABASE_ID=YOUR_FIRESTORE_DATABASE_ID 

